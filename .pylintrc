[MASTER]
ignore=CVS

[MESSAGES CONTROL]
disable=
    missing-docstring,
    empty-docstring,
    invalid-name,
    line-too-long,
    too-many-locals,
    too-many-branches,
    too-many-statements,
    too-many-ancestors,
    too-many-instance-attributes,
    too-few-public-methods,
    too-many-arguments,
    too-many-positional-arguments,
    wrong-import-position,
    import-outside-toplevel,
    wrong-import-order,
    broad-exception-caught,
    global-statement,
    subprocess-run-check,
    disallowed-name,
    attribute-defined-outside-init,
    unused-argument,
    superfluous-parens,
    duplicate-code
